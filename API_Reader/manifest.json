{
  "manifest_version": 3,
  "name": "PM API Inspector",
  "version": "1.0",
  "description": "Simplified API Inspector for Product Managers",
  "permissions": [
    "debugger",
    "tabs",
    "storage",
    "activeTab"
  ],
  "background": {
    "service_worker": "service_worker.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
